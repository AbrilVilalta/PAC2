<Window x:Class="DLL_AbrilVilalta_MosiesCuartero.DeleteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Accent color for the left bar and button -->
        <SolidColorBrush x:Key="AccentBrush" Color="#F5C542"/>
        <SolidColorBrush x:Key="DialogBg"    Color="#1E1E2E"/>
        <SolidColorBrush x:Key="DialogCard"  Color="#2A2A3E"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F0F0F8"/>
        <SolidColorBrush x:Key="TextSecond"  Color="#9090A8"/>
    </Window.Resources>

    <!-- Drop shadow wrapper -->
    <Border CornerRadius="12"
            Background="{StaticResource DialogBg}"
            BorderBrush="#3A3A52"
            BorderThickness="1"
            MinWidth="340"
            MaxWidth="420">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4"
                              Direction="270" Opacity="0.5"
                              Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Coloured top bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="12,12,0,0"
                    Height="4"/>

            <!-- Icon + title + message -->
            <StackPanel Grid.Row="1" Margin="28,22,28,18">

                <!-- Icon row -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <!-- Circle with "!" -->
                    <Grid Width="36" Height="36" Margin="0,0,12,0">
                        <Polygon Points="18,4 34,32 2,32"
                             Fill="{StaticResource AccentBrush}"
                             Opacity="0.18"/>
                        <Polygon Points="18,4 34,32 2,32"
                             Fill="Transparent"
                             Stroke="{StaticResource AccentBrush}"
                             StrokeThickness="1.5"
                             StrokeLineJoin="Round"/>
                        <TextBlock Text="!"
                             FontSize="15"
                             FontWeight="Bold"
                             Foreground="{StaticResource AccentBrush}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Margin="0,6,0,0"/>
                    </Grid>

                    <!-- Title -->
                    <TextBlock x:Name="TitleText"
                               Text="Error"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Message -->
                <TextBlock x:Name="MessageText"
                           Text=""
                           FontSize="13"
                           Foreground="{StaticResource TextSecond}"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           Margin="0,0,0,4"/>
            </StackPanel>

            <Border Grid.Row="2"
        Background="#24243A"
        CornerRadius="0,0,12,12"
        Padding="20,14">
                <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right">

                    <!-- Botó Cancel·lar -->
                    <Button x:Name="CancelButton"
                Content="Cancel·lar"
                Click="CancelButton_Click"
                Width="100" Height="34"
                FontSize="13"
                FontWeight="SemiBold"
                Cursor="Hand"
                Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#2A2A42"/>
                                <Setter Property="Foreground" Value="#A0A0C0"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="#3A3A5C"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#33334F"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" Value="#1E1E35"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Botó Acceptar -->
                    <Button x:Name="OkButton"
                Content="Acceptar"
                Click="OkButton_Click"
                Width="100" Height="34"
                FontSize="13"
                FontWeight="SemiBold"
                Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#C9A832"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" Value="#A88A28"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
