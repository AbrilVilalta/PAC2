<Window x:Class="WPF_MVVM_SPA_Template.Views.CustomDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Accent color for the left bar and button -->
        <SolidColorBrush x:Key="AccentBrush" Color="#E05252"/>
        <SolidColorBrush x:Key="DialogBg"    Color="#1E1E2E"/>
        <SolidColorBrush x:Key="DialogCard"  Color="#2A2A3E"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F0F0F8"/>
        <SolidColorBrush x:Key="TextSecond"  Color="#9090A8"/>
    </Window.Resources>

    <!-- Drop shadow wrapper -->
    <Border CornerRadius="12"
            Background="{StaticResource DialogBg}"
            BorderBrush="#3A3A52"
            BorderThickness="1"
            MinWidth="340"
            MaxWidth="420">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4"
                              Direction="270" Opacity="0.5"
                              Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Coloured top bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="12,12,0,0"
                    Height="4"/>

            <!-- Icon + title + message -->
            <StackPanel Grid.Row="1" Margin="28,22,28,18">

                <!-- Icon row -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <!-- Circle with "!" -->
                    <Grid Width="36" Height="36" Margin="0,0,12,0">
                        <Ellipse Fill="{StaticResource AccentBrush}" Opacity="0.18"/>
                        <Ellipse Fill="Transparent"
                                 Stroke="{StaticResource AccentBrush}"
                                 StrokeThickness="1.5"/>
                        <TextBlock Text="!"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Title -->
                    <TextBlock x:Name="TitleText"
                               Text="Error"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Message -->
                <TextBlock x:Name="MessageText"
                           Text=""
                           FontSize="13"
                           Foreground="{StaticResource TextSecond}"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           Margin="0,0,0,4"/>
            </StackPanel>

            <!-- Button row -->
            <Border Grid.Row="2"
                    Background="#24243A"
                    CornerRadius="0,0,12,12"
                    Padding="20,14">
                <Button x:Name="OkButton"
                        Content="Acceptar"
                        Click="OkButton_Click"
                        HorizontalAlignment="Right"
                        Width="100" Height="34"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#C04040"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#A03030"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
