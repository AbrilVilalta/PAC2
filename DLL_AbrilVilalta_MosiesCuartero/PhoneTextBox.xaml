<UserControl x:Class="DLL_AbrilVilalta_MosiesCuartero.PhoneTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DLL_AbrilVilalta_MosiesCuartero"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WPF-MVVM-SPA-Template;component/Assets/Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="/WPF-MVVM-SPA-Template;component/Assets/Themes/GlobalStyles.xaml"/>
                <ResourceDictionary Source="/WPF-MVVM-SPA-Template;component/Assets/Themes/FontSize.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- TextBox takes all available space -->
            <ColumnDefinition Width="*"/>
            <!-- Fixed width for the error indicator circle -->
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Main TextBox input -->
        <TextBox x:Name="PhoneTextBoxControl"
                 Grid.Column="0"
                 Style="{StaticResource ModernTextBoxStyle}"
                 Tag="123456789"
                 BorderBrush="{Binding BorderColor, 
                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                 Text="{Binding Phone, Mode=TwoWay, 
                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                 ToolTip="{Binding TooltipMessage, 
                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                 ToolTipService.IsEnabled="True"/>

        <!-- Error indicator: red circle with "!" shown only when invalid -->
        <Ellipse Grid.Column="1"
                 Width="18"
                 Height="18"
                 Margin="6,0,0,0"
                 VerticalAlignment="Center"
                 Fill="LightCoral"
                 Visibility="{Binding ErrorIndicatorVisibility, 
                     RelativeSource={RelativeSource AncestorType=UserControl}}">
            <Ellipse.ToolTip>
                <ToolTip>
                    <TextBlock Text="{Binding TooltipMessage, 
                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                               MaxWidth="220"
                               TextWrapping="Wrap"/>
                </ToolTip>
            </Ellipse.ToolTip>
        </Ellipse>

        <!-- "!" label inside the error circle -->
        <TextBlock Grid.Column="1"
                   Text="!"
                   FontWeight="Bold"
                   FontSize="11"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="6,0,0,0"
                   IsHitTestVisible="False"
                   Visibility="{Binding ErrorIndicatorVisibility, 
                       RelativeSource={RelativeSource AncestorType=UserControl}}"/>
    </Grid>
</UserControl>
