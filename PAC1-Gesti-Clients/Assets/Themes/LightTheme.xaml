
<!--
    ════════════════════════════════════════════════════════════════════
    ░  BRUSH RESOURCE DICTIONARY (LIGTH THEME)
    ════════════════════════════════════════════════════════════════════
     Contains all the color brushes for the ligth theme
    ════════════════════════════════════════════════════════════════════
-->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- General -->
    <SolidColorBrush x:Key="MainBackgroundBrush"                   Color="#F4F5F9"/>
    <SolidColorBrush x:Key="PrimaryTextBrush"                      Color="#1A1D2E"/>
    <SolidColorBrush x:Key="SecondaryTextBrush"                    Color="#6B7080"/>
    <SolidColorBrush x:Key="ThemeIconColor"                        Color="#3A3F60"/>
    <SolidColorBrush x:Key="DividerBrush"                          Color="#E2E4EE"/>

    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush"                Color="#ECEEF6"/>
    <SolidColorBrush x:Key="SidebarForegroundBrush"                Color="#4A5070"/>
    <SolidColorBrush x:Key="SidebarHoverBackgroundBrush"           Color="#DDE0EE"/>
    <SolidColorBrush x:Key="SidebarSelectedBackgroundBrush"        Color="#DCD8FC"/>
    <SolidColorBrush x:Key="SidebarAccentBrush"                    Color="#5B4EE8"/>

    <!-- Primary button -->
    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush"          Color="#5B4EE8"/>
    <SolidColorBrush x:Key="PrimaryButtonBorderBrush"              Color="#7C6AF5"/>
    <SolidColorBrush x:Key="PrimaryButtonHoverBackgroundBrush"     Color="#7C6AF5"/>
    <SolidColorBrush x:Key="PrimaryButtonDisabledBackgroundBrush"  Color="#C8CADC"/>
    <SolidColorBrush x:Key="PrimaryButtonDisabledBorderBrush"      Color="#B0B4CC"/>
    <SolidColorBrush x:Key="PrimaryButtonDisabledForegroundBrush"  Color="#8A8FA8"/>

    <!-- Secondary button -->
    <SolidColorBrush x:Key="SecondaryButtonForegroundBrush"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush"          Color="#C0304A"/>
    <SolidColorBrush x:Key="SecondaryButtonBorderBrush"              Color="#D94060"/>
    <SolidColorBrush x:Key="SecondaryButtonHoverBackgroundBrush"     Color="#D94060"/>
    <SolidColorBrush x:Key="SecondaryButtonDisabledBackgroundBrush"  Color="#EABEC6"/>
    <SolidColorBrush x:Key="SecondaryButtonDisabledBorderBrush"      Color="#D9A0AC"/>
    <SolidColorBrush x:Key="SecondaryButtonDisabledForegroundBrush"  Color="#B07080"/>

    <!-- DataGrid -->
    <SolidColorBrush x:Key="DataGridBackgroundBrush"               Color="#F4F5F9"/>
    <SolidColorBrush x:Key="DataGridHeaderBackgroundBrush"         Color="#ECEEF6"/>
    <SolidColorBrush x:Key="DataGridHeaderForegroundBrush"         Color="#8B90A8"/>
    <SolidColorBrush x:Key="DataGridForegroundBrush"               Color="#2C3048"/>
    <SolidColorBrush x:Key="DataGridRowBackgroundBrush"            Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DataGridRowAlternateBackgroundBrush"   Color="#F7F8FC"/>
    <SolidColorBrush x:Key="DataGridGridLinesBrush"                Color="#E2E4EE"/>
    <SolidColorBrush x:Key="DataGridSelectionBackgroundBrush"      Color="#DCD8FC"/>
    <SolidColorBrush x:Key="DataGridSelectionForegroundBrush"      Color="#1A1D2E"/>

    <!-- Input -->
    <SolidColorBrush x:Key="InputBackgroundBrush"                  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBorderBrush"                      Color="#D8DAE8"/>
    <SolidColorBrush x:Key="InputFocusBorderBrush"                 Color="#5B4EE8"/>
    <SolidColorBrush x:Key="InputForegroundBrush"                  Color="#1A1D2E"/>
    <SolidColorBrush x:Key="InputPlaceholderBrush"                 Color="#AAACC0"/>
    <SolidColorBrush x:Key="InputHoverBorderBrush"                 Color="#A8A4F0"/>

    <!-- Card -->
    <SolidColorBrush x:Key="CardBackgroundBrush"                   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBorderBrush"                       Color="#E2E4EE"/>

    <!-- Status -->
    <SolidColorBrush x:Key="SuccessBrush"                          Color="#15A870"/>
    <SolidColorBrush x:Key="WarningBrush"                          Color="#D4820A"/>
    <SolidColorBrush x:Key="ErrorBrush"                            Color="#C0304A"/>
    <SolidColorBrush x:Key="InfoBrush"                             Color="#5B4EE8"/>

</ResourceDictionary>