<UserControl x:Class="WPF_MVVM_SPA_Template.Views.SettingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WPF_MVVM_SPA_Template.Views"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{DynamicResource MainBackgroundBrush}">

    <UserControl.Resources>

        <!-- Card section wrapper -->
        <Style x:Key="SettingsSectionCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="32,24"/>
            <Setter Property="Margin"          Value="0,0,0,16"/>
        </Style>

        <!-- Section heading -->
        <Style x:Key="SectionHeading" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="{DynamicResource font-size-xs}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,14"/>
        </Style>

        <!-- Row label -->
        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="{DynamicResource font-size-sm}"/>
            <Setter Property="FontWeight"        Value="Medium"/>
            <Setter Property="Foreground"        Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Row sublabel -->
        <Style x:Key="RowSubLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="{DynamicResource font-size-xs}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Opacity"    Value="0.75"/>
            <Setter Property="Margin"     Value="0,3,0,0"/>
        </Style>

        <!-- Thin divider -->
        <Style x:Key="RowDivider" TargetType="Border">
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Background" Value="{DynamicResource DataGridGridLinesBrush}"/>
            <Setter Property="Margin"     Value="0,14"/>
            <Setter Property="Opacity"    Value="0.5"/>
        </Style>

        <!-- Theme pill toggle button -->
        <Style x:Key="ThemePillStyle" TargetType="Button">
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Width"           Value="130"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="{DynamicResource font-size-xs}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="{DynamicResource PrimaryButtonForegroundBrush}"/>
            <Setter Property="Background"      Value="{DynamicResource PrimaryButtonBackgroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="18"
                                Padding="14,0">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="Icon"
                                           Text="☾"
                                           Margin="0,0,6,0"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryButtonForegroundBrush}"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Font chip — inactive -->
        <Style x:Key="FontChipStyle" TargetType="Button">
            <Setter Property="Height"          Value="36"/>
            <Setter Property="MinWidth"        Value="100"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,8,8"/>
            <Setter Property="FontSize"        Value="{DynamicResource font-size-xs}"/>
            <Setter Property="Foreground"      Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Background"      Value="{DynamicResource MainBackgroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="14,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource SidebarAccentBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource PrimaryTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Font chip — active -->
        <Style x:Key="FontChipActiveStyle" TargetType="Button">
            <Setter Property="Height"          Value="36"/>
            <Setter Property="MinWidth"        Value="100"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,8,8"/>
            <Setter Property="FontSize"        Value="{DynamicResource font-size-xs}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="{DynamicResource PrimaryButtonForegroundBrush}"/>
            <Setter Property="Background"      Value="{DynamicResource PrimaryButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource PrimaryButtonBackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="14,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="{DynamicResource MainBackgroundBrush}">

        <Grid Margin="32,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Page title -->
            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                       Text="Settings"
                       FontSize="{DynamicResource font-size-xl}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Margin="0,0,0,24"/>

            <!-- ══ LEFT COLUMN ══════════════════════════════════════════ -->
            <StackPanel Grid.Row="1" Grid.Column="0">

                <Border Style="{StaticResource SettingsSectionCard}">
                    <StackPanel>
                        <TextBlock Text="APPEARANCE" Style="{StaticResource SectionHeading}"/>

                        <!-- Theme row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Theme" Style="{StaticResource RowLabel}"/>
                                <TextBlock x:Name="ThemeSubLabel"
                                           Text="Currently: Dark"
                                           Style="{StaticResource RowSubLabel}"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    x:Name="ThemeToggleBtn"
                                    Content="Dark mode"
                                    Style="{StaticResource ThemePillStyle}"
                                    Click="ThemeToggleBtn_Click"/>
                        </Grid>

                        <Border Style="{StaticResource RowDivider}"/>

                        <!-- Font family row -->
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Font family" Style="{StaticResource RowLabel}"/>
                                    <TextBlock Text="Choose the typeface used across the application"
                                               Style="{StaticResource RowSubLabel}"/>
                                </StackPanel>
                            </Grid>
                            <WrapPanel x:Name="FontChipsPanel">
                                <Button Content="Segoe UI"     Tag="Segoe UI"     Style="{StaticResource FontChipActiveStyle}" Click="FontChip_Click"/>
                                <Button Content="Inter"        Tag="Inter"        Style="{StaticResource FontChipStyle}"       Click="FontChip_Click"/>
                                <Button Content="Consolas"     Tag="Consolas"     Style="{StaticResource FontChipStyle}"       Click="FontChip_Click"/>
                                <Button Content="Georgia"      Tag="Georgia"      Style="{StaticResource FontChipStyle}"       Click="FontChip_Click"/>
                                <Button Content="Trebuchet MS" Tag="Trebuchet MS" Style="{StaticResource FontChipStyle}"       Click="FontChip_Click"/>
                            </WrapPanel>
                        </StackPanel>

                        <Border Style="{StaticResource RowDivider}"/>

                        <!-- Font size row — label, chips -->
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Font size" Style="{StaticResource RowLabel}"/>
                                    <TextBlock x:Name="FontSizeSubLabel"
                                               Text="Currently: Medium (14 px)"
                                               Style="{StaticResource RowSubLabel}"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="S"
                                        Tag="Small"
                                        Width="60"
                                        Style="{StaticResource FontChipStyle}"
                                        Click="FontSizeChip_Click"/>
                                <Button Content="M"
                                        Tag="Medium"
                                        Width="60"
                                        x:Name="FontSizeMediumBtn"
                                        Style="{StaticResource FontChipActiveStyle}"
                                        Click="FontSizeChip_Click"/>
                                <Button Content="L"
                                        Tag="Large"
                                        Width="60"
                                        Style="{StaticResource FontChipStyle}"
                                        Click="FontSizeChip_Click"/>
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- ══ RIGHT COLUMN ═══════════════════════════════════════════ -->
            <StackPanel Grid.Row="1" Grid.Column="2">

                <Border Style="{StaticResource SettingsSectionCard}">
                    <StackPanel>
                        <TextBlock Text="ABOUT" Style="{StaticResource SectionHeading}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="WPF MVVM SPA Template" Style="{StaticResource RowLabel}"/>
                            <TextBlock Grid.Column="1" Text="v1.0.0"
                                       Style="{StaticResource RowSubLabel}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Border Style="{StaticResource RowDivider}"/>

                        <StackPanel>
                            <TextBlock Text="Framework"    Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                            <TextBlock Text="WPF · .NET 8" Style="{StaticResource RowSubLabel}"/>
                        </StackPanel>

                        <Border Style="{StaticResource RowDivider}"/>

                        <StackPanel>
                            <TextBlock Text="Pattern"   Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                            <TextBlock Text="MVVM + SPA" Style="{StaticResource RowSubLabel}"/>
                        </StackPanel>

                        <Border Style="{StaticResource RowDivider}"/>

                        <StackPanel>
                            <TextBlock Text="Charting" Style="{StaticResource RowLabel}" Margin="0,0,0,2"/>
                            <TextBlock Text="OxyPlot"  Style="{StaticResource RowSubLabel}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>

        </Grid>
    </ScrollViewer>
</UserControl>
